import { Response, NextFunction } from "express";
import { getUserClient } from "../lib/supabaseClients";
import type { AuthenticatedRequest } from "../types/requestContext";

export async function detectPlatformAdmin(
  req: AuthenticatedRequest,
  _res: Response,
  next: NextFunction
) {
  try {
    const token = req.user?.token?.trim();

    if (!token) {
      req.isPlatformAdmin = false;
      return next();
    }

    const supabase = getUserClient(token);

    const { data, error } = await supabase
      .from("platform_admins")
      .select("user_id")
      .eq("user_id", req.user?.id)
      .single();

    if (error || !data) {
      req.isPlatformAdmin = false;
    } else {
      req.isPlatformAdmin = true;
    }

    return next();
  } catch {
    req.isPlatformAdmin = false;
    return next();
  }
}
